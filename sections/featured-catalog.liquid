<section class="catalog" id="catalog">
  <div class="bg-watermark">{{ section.settings.watermark_text | upcase }}</div>
  <div class="container">
    <div class="products-header reveal">
      <span class="eyebrow">{{ section.settings.eyebrow_text | upcase }}</span>
      <h2>{{ section.settings.section_title }}</h2>
      <p>{{ section.settings.section_description }}</p>
    </div>

    <div class="products-grid reveal-stagger">
      {% assign featured_collection = collections[section.settings.collection_source] %}
      {% for product in featured_collection.products limit: 3 %}
        <div class="product-card" data-id="{{ product.variants.first.id }}">
          <div>
            <div class="product-img-box">
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" class="product-real-img">
            </div>
            <div class="product-info">
              <span class="product-actives-pill">
                {% if product.metafields.custom.actives_summary != blank %}
                  {{ product.metafields.custom.actives_summary }}
                {% else %}
                  Clinical Actives Formula
                {% endif %}
              </span>
              <h3>{{ product.title }}</h3>
              <div class="product-bullets" style="padding: 10px 0; font-size: 0.9rem; color: var(--charcoal);">
                {{ product.description | truncatewords: 25 }}
              </div>
            </div>
          </div>
          <div class="product-footer">
            <div class="price-container">
              <span class="price-label">M.R.P.</span>
              <span class="price-mrp">{{ product.price | money_without_trailing_zeros }}</span>
            </div>
            <button class="add-to-cart-btn" 
                    data-variant-id="{{ product.variants.first.id }}" 
                    onclick="addItemToShopifyCart({{ product.variants.first.id }})"
                    aria-label="Add to cart">+</button>
          </div>
        </div>
      {% else %}
        {% for i in (1..3) %}
          <div class="product-card">
            <h3>Placeholder Product {{ i }}</h3>
            <div class="product-footer"><span>₹299</span></div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dynamic Product Grid",
  "settings": [
    { "type": "text", "id": "watermark_text", "label": "Watermark Background Text", "default": "THE ESSENTIALS" },
    { "type": "text", "id": "eyebrow_text", "label": "Section Accent Eyebrow Label", "default": "THE SERIES" },
    { "type": "text", "id": "section_title", "label": "Section Title Header", "default": "Three Products. One Complete Routine." },
    { "type": "textarea", "id": "section_description", "label": "Section Summary Text" },
    { "type": "collection", "id": "collection_source", "label": "Source Product Collection" }
  ],
  "presets": [{ "name": "Dynamic Product Grid" }]
}
{% endschema %}
